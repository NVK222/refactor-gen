{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "ES2020",
        "outDir": "./out",
        "lib": [
            "ES2020"
        ],
        "sourceMap": true,
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "verbatimModuleSyntax": false,
    },
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}
